# development | production — Docker deploy forces production on the container;
# set production here too if you use npm start on the VPS without Docker.
NODE_ENV=development

PORT=3000

# Required from PIN slice (#2) onward
SESSION_SECRET=
CLUB_PIN=

# Trainer-only password that gates the /report page (must differ from CLUB_PIN
# so members cannot see who checked in). Required.
TRAINER_PIN=

# Required from Google Sheets slice (#4) onward
SPREADSHEET_ID=
# Service account JSON at repo root (same folder as .env). Use ../api-key.json — paths are
# resolved from the api/ working directory. Docker uses /app/api-key.json via compose mount.
GOOGLE_SERVICE_ACCOUNT=../api-key.json

# Club calendar (API defaults to Europe/Stockholm if unset)
TZ=Europe/Stockholm

# Display name of the default group everyone belongs to (defaults to "Standard").
# Shown when a member checks in and in settings.
DEFAULT_GROUP_NAME=Standard
