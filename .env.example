# Optional for scaffold (health + static SPA)
PORT=3000

# Required from PIN slice (#2) onward
SESSION_SECRET=
CLUB_PIN=

# Required from Google Sheets slice (#4) onward
SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT=./secrets/service-account.json

# Club calendar (API defaults to Europe/Stockholm if unset)
TZ=Europe/Stockholm

# Required when GDPR consent is enforced (#3)
GDPR_POLICY_VERSION=1
